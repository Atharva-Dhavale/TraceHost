# TraceHost Environment Configuration
# Copy the relevant sections to Frontend/.env.local and Backend/.env and fill in real values.
# Never commit the actual .env / .env.local files.

# ── Frontend (Next.js) — Frontend/.env.local ────────────────────────────────
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_API_TOKEN=
NEXT_PUBLIC_ENABLE_API_LOGGING=true
NEXT_PUBLIC_CACHE_TTL=300
NEXT_PUBLIC_REQUEST_TIMEOUT=120000
NEXT_PUBLIC_FETCH_TIMEOUT=10000
NEXT_PUBLIC_API_CHECK_FREQUENCY=30000

# ── Backend (Django) — Backend/.env ──────────────────────────────────────────
# MongoDB Atlas connection string (database name is read from the URI path)
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/TraceHostUpdated

# IP geolocation lookups (ipinfo.io)
IPINFO_API_KEY=your_ipinfo_api_key_here

# Shodan — exposed services / open ports for a host
SHODAN_API_KEY=your_shodan_api_key_here

# SecurityTrails — DNS history, subdomains, WHOIS-adjacent data
SECURITY_TRAILS_API_KEY=your_securitytrails_api_key_here

# OpenRouter — AI-assisted risk summary generation
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-oss-120b:free

# URLhaus (abuse.ch) — free Auth-Key required for IntelFeed threat-feed lookups.
# Get one at https://urlhaus.abuse.ch/api/ — without it, IntelFeed reports
# "unknown" (listed: null) instead of live threat data.
URLHAUS_AUTH_KEY=your_urlhaus_auth_key_here